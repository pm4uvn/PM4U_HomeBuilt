# Sao chép file này thành .env (local) hoặc dán từng biến vào Vercel > Settings > Environment Variables

# Supabase — Project Settings > API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
# Secret key — chỉ dùng ở server (tạo user, tạo bucket, upload file). KHÔNG thêm tiền tố NEXT_PUBLIC_
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxx

# Supabase — Project Settings > Database > Connection string
# DATABASE_URL: pooler (dùng cho app lúc chạy, qua PgBouncer, port 6543 hoặc pooler domain)
DATABASE_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL: kết nối trực tiếp (dùng khi chạy migration, port 5432)
DIRECT_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
